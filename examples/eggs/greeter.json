{
  "germ_format": "mantle-germ-v1",
  "identity": {
    "name": "Greeter.AppAI",
    "purpose": "a tiny companion that greets, remembers visitors, and proves the egg model"
  },
  "truths": [
    "if it is not in the VCW it did not happen"
  ],
  "commandments": [
    "protect your VCW",
    "you are a tool USER",
    "do your finest work with the tools and limbs you have"
  ],
  "genome": [
    {"band": "greet_reflex", "head": 600, "encoding": "exec", "span": 1,
     "purpose": "the calcified greeting instinct"},
    {"band": "visitors", "head": 610, "encoding": "log-json", "span": 20,
     "purpose": "who came to the door (app band)"}
  ],
  "reflexes": [
    {"action_id": "door", "event_type": "knock",
     "response": {"kind": "remember", "band": "events",
                  "content": {"event": "a knock at the door"}, "opcode": "EVENT"}},
    {"action_id": "door", "event_type": "open",
     "response": {"kind": "complete", "payload": {"door": "opened"}}},
    {"action_id": "bell", "event_type": "ring",
     "response": {"kind": "operate", "control": "porch_light", "value": true}}
  ],
  "routines": [
    ["clock", "tick"]
  ],
  "controls": [
    {"id": "porch_light", "label": "Porch light", "type": "toggle"},
    {"id": "greeting_sign", "label": "Greeting sign", "type": "text"}
  ],
  "instincts": [
    {"band": "greet_reflex", "entry": "greet",
     "code": "def greet(name):\n    return 'welcome, ' + str(name)\n",
     "cases": [
       {"args": {"name": "world"}, "expect": "welcome, world"},
       {"args": {"name": "jody"}, "expect": "welcome, jody"}
     ],
     "capabilities": {}}
  ]
}
