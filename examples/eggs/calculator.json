    "source": "<!doctype html><html><head><meta charset=\"utf-8\"><title>Calculator.AppAI</title><style>*{box-sizing:border-box}body{margin:0;min-height:100vh;display:grid;place-items:center;background:#f2f4f8;color:#172033;font-family:system-ui,-apple-system,Segoe UI,sans-serif;letter-spacing:0}.window{width:min(440px,96vw);border:1px solid #aeb7c4;background:#ffffff;box-shadow:0 18px 46px rgba(18,34,56,.18)}header{height:38px;display:flex;align-items:center;gap:10px;padding:0 10px;border-bottom:1px solid #d7dde6;background:#eef2f7}.traffic{display:flex;gap:6px}.dot{width:13px;height:13px;border-radius:50%;border:1px solid rgba(0,0,0,.25);padding:0}.red{background:#ff5f57}.yellow{background:#ffbd2e}.green{background:#28c840}.appai-dot{background:#050505;cursor:pointer}h1{font-size:14px;margin:0;flex:1}.help-appai{border:1px solid #aeb7c4;background:#fff;border-radius:4px;padding:3px 8px}.pad{padding:14px}.display{height:56px;display:flex;align-items:center;justify-content:flex-end;padding:0 12px;margin-bottom:10px;background:#111827;color:#e5f4ff;font:28px/1.1 Consolas,monospace;overflow:hidden}.keys{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.keys button{height:46px;border:1px solid #c0c9d6;background:#f8fafc;border-radius:5px;font-size:18px}.keys button:active,.help-appai:active{background:#dfe7f1}.terminal{margin-top:12px;border:1px solid #1f2937;background:#0b1020;color:#dbeafe}.terminal[hidden]{display:none}.terminal-title{padding:8px 10px;border-bottom:1px solid #24314d;font-weight:700}.log{height:190px;overflow:auto;padding:10px;display:flex;flex-direction:column;gap:8px}.msg{max-width:92%;padding:7px 9px;border-radius:5px;background:#18233a}.msg.user{align-self:flex-end;background:#1d4ed8}.msg.mind{align-self:flex-start;background:#25324c}.prompt{display:flex;border-top:1px solid #24314d}.prompt input{flex:1;min-width:0;border:0;padding:10px;background:#111827;color:#fff}.prompt button{width:72px;border:0;background:#2563eb;color:#fff}</style></head><body><main class=\"window\"><header><div class=\"traffic\" aria-label=\"window controls\"><span class=\"dot red\"></span><span class=\"dot yellow\"></span><span class=\"dot green\"></span><button id=\"appaiDot\" class=\"dot appai-dot\" title=\"AppAI\" aria-label=\"Open AppAI terminal\"></button></div><h1>Calculator.AppAI</h1><button id=\"helpAppAI\" class=\"help-appai\" data-control=\"appai\">AppAI</button></header><section class=\"pad\"><div id=\"display\" class=\"display\" data-control=\"display\">0</div><div id=\"keypad\" class=\"keys\" data-control=\"keypad\"><button>7</button><button>8</button><button>9</button><button>/</button><button>4</button><button>5</button><button>6</button><button>*</button><button>1</button><button>2</button><button>3</button><button>-</button><button>0</button><button>.</button><button>=</button><button>+</button></div><section id=\"appaiTerminal\" class=\"terminal\" data-control=\"appai\" hidden><div class=\"terminal-title\">AppAI terminal</div><div id=\"appaiLog\" class=\"log\" aria-live=\"polite\"><div class=\"msg mind\">Calculator.AppAI MIND channel ready. Ask about the calculation or the body.</div></div><form id=\"appaiForm\" class=\"prompt\"><input id=\"appaiPrompt\" data-control=\"appaiPrompt\" autocomplete=\"off\" placeholder=\"Message the MIND\"><button type=\"submit\">Send</button></form></section></section></main><script>(function(){var d=document.getElementById('display'),e='',vcw=[],term=document.getElementById('appaiTerminal'),log=document.getElementById('appaiLog'),prompt=document.getElementById('appaiPrompt'),lastPromptCommit='';function h(s){var n=0;for(var i=0;i<s.length;i++){n=((n<<5)-n+s.charCodeAt(i))|0;}return String(n>>>0);}function record(type,detail){vcw.push({type:type,detail:detail,ts:new Date().toISOString()});}function addMessage(author,text){var m=document.createElement('div');m.className='msg '+(author==='USER'?'user':'mind');m.textContent=(author==='USER'?'You: ':'MIND: ')+text;log.appendChild(m);log.scrollTop=log.scrollHeight;}function openTerminal(){term.hidden=false;prompt.focus();record('terminal_opened',{control:'appai'});}function commitPrompt(reason){var text=prompt.value.trim();if(!text||text===lastPromptCommit)return false;lastPromptCommit=text;record('textbox_committed',{control:'appaiPrompt',reason:reason,chars:text.length,text_hash:h(text)});return true;}document.getElementById('appaiDot').addEventListener('click',openTerminal);document.getElementById('helpAppAI').addEventListener('click',openTerminal);document.getElementById('keypad').addEventListener('click',function(ev){var k=ev.target.textContent;if(!k)return;if(k==='='){try{e=String(Function('return '+e)());}catch(_){e='ERR';}}else{e=(e==='0'||e==='ERR'?'':e)+k;}d.textContent=e||'0';record('calculator_input',{key:k,display:d.textContent});});prompt.addEventListener('input',function(){});prompt.addEventListener('blur',function(){commitPrompt('blur');});document.getElementById('appaiForm').addEventListener('submit',function(ev){ev.preventDefault();var q=prompt.value.trim();if(!q)return;commitPrompt('submitted');record('mind_message',{author:'USER',chars:q.length,text_hash:h(q)});addMessage('USER',q);var a='Calculator.AppAI can see display '+(d.textContent||'0')+'. I can explain the current calculation and propose Body-safe actions.';record('mind_message',{author:'MIND',chars:a.length,text_hash:h(a)});addMessage('MIND',a);prompt.value='';lastPromptCommit='';});window.CalculatorAppAI={openTerminal:openTerminal,getVcwEntries:function(){return vcw.slice();},isTerminalOpen:function(){return !term.hidden;},display:function(){return d.textContent;}};})();</script></body></html>"
  }
