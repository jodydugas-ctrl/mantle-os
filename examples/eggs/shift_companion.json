        "id": "clear_done",
        "label": "Clear done",
        "type": "button"
      }
    ],
    "source": "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Shift.Companion.AppAI</title><style>body{margin:0;font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:#08111f;color:#edf7ff}main{max-width:1040px;margin:auto;padding:28px}h1{font-size:clamp(2rem,5vw,4rem);margin:.2rem 0}.lede{color:#bfd8ea;max-width:68ch;line-height:1.55}.grid{display:grid;grid-template-columns:1fr 1.35fr;gap:16px}form,section{border:1px solid #31516a;background:#0d1a2bcc;border-radius:22px;padding:18px;box-shadow:0 24px 80px #0006}label{display:grid;gap:6px;margin:10px 0;color:#d8eeff}input,textarea,select,button{font:inherit;border-radius:14px;border:1px solid #31516a}input,textarea,select{width:100%;box-sizing:border-box;padding:11px 12px;color:#edf7ff;background:#ffffff10}textarea{min-height:105px}button{cursor:pointer;padding:11px 14px;color:#06101e;background:linear-gradient(135deg,#8bd8ff,#83ffc6);font-weight:800;border:0}.secondary{color:#d8eeff;background:#ffffff12;border:1px solid #31516a}.row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}.task{border:1px solid #31516a;background:#ffffff0b;padding:14px;border-radius:18px;margin-bottom:10px}.done{opacity:.55;text-decoration:line-through}.meta{display:flex;gap:8px;flex-wrap:wrap;color:#9fc7df;font-size:.84rem}.pill{border:1px solid #31516a;border-radius:999px;padding:3px 8px;color:#caf0ff}.High{color:#ffd1d1}.Medium{color:#ffe9ad}.Low{color:#caffdd}pre{white-space:pre-wrap;background:#0005;border-radius:18px;padding:14px;min-height:120px}.empty{color:#91b8ce;border:1px dashed #31516a;border-radius:18px;padding:18px;text-align:center}@media(max-width:820px){.grid,.row{grid-template-columns:1fr}}</style></head><body><main><p style=\"color:#8bd8ff;letter-spacing:.18em;text-transform:uppercase;font-weight:800\">Mantle OS · AppAI origin face</p><h1>Shift.Companion.AppAI</h1><p class=\"lede\">A tiny handoff/task web applet born as a Mantle egg face. It keeps shift notes local to this browser, exports plain-text handoff notes, and never offers clinical advice or diagnosis.</p><div class=\"grid\"><form id=\"task_form\" data-control=\"task_form\"><h2>Add handoff item</h2><div class=\"row\"><label>Room or label<input id=\"room\" autocomplete=\"off\" placeholder=\"e.g. 204B\"></label><label>Priority<select id=\"priority\"><option>High</option><option selected>Medium</option><option>Low</option></select></label></div><label>Need / reminder<textarea id=\"need\" placeholder=\"e.g. family update requested, restock supplies, clarify paperwork\"></textarea></label><button>Add to shift board</button></form><section><div class=\"toolbar\"><button id=\"handoff_export\" data-control=\"handoff_export\">Export handoff</button><button id=\"clear_done\" class=\"secondary\" data-control=\"clear_done\">Clear done</button><button id=\"reset\" class=\"secondary\">Reset board</button></div><div id=\"task_list\" data-control=\"task_list\"></div><h2>Handoff text</h2><pre id=\"handoff\">No handoff exported yet.</pre></section></div></main><template id=\"task_template\"><article class=\"task\"><div class=\"meta\"></div><strong class=\"need\"></strong><p><button class=\"secondary toggle\" type=\"button\">Mark done</button></p></article></template><script>(()=>{const key=\"shift-companion-appai-v1\",$=id=>document.getElementById(id);let tasks=JSON.parse(localStorage.getItem(key)||\"[]\");const save=()=>localStorage.setItem(key,JSON.stringify(tasks));const esc=v=>String(v).replace(/[&<>\"']/g,c=>({\"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\",\"\\\"\":\"&quot;\",\"'\":\"&#39;\"}[c]||c));const rank=p=>({High:0,Medium:1,Low:2}[p]??3);function render(){const list=$(\"task_list\");list.innerHTML=\"\";if(!tasks.length){list.innerHTML='<div class=\"empty\">The board is clear. A rare moonbeam on a busy floor.</div>';return}const tpl=$(\"task_template\");tasks.slice().sort((a,b)=>(a.done-b.done)||rank(a.priority)-rank(b.priority)).forEach(t=>{const n=tpl.content.firstElementChild.cloneNode(true);n.classList.toggle(\"done\",t.done);n.querySelector(\".meta\").innerHTML='<span class=\"pill\">'+esc(t.room||\"No room\")+'</span><span class=\"'+t.priority+'\">'+esc(t.priority)+'</span><span>'+new Date(t.created).toLocaleTimeString([],{hour:\"2-digit\",minute:\"2-digit\"})+\"</span>\";n.querySelector(\".need\").textContent=t.need;n.querySelector(\".toggle\").textContent=t.done?\"Reopen\":\"Mark done\";n.querySelector(\".toggle\").onclick=()=>{t.done=!t.done;save();render()};list.appendChild(n)})}$(\"task_form\").onsubmit=e=>{e.preventDefault();const need=$(\"need\").value.trim();if(!need)return;tasks.push({id:String(Date.now())+Math.random(),room:$(\"room\").value.trim(),priority:$(\"priority\").value,need,done:false,created:Date.now()});$(\"need\").value=\"\";save();render()};$(\"handoff_export\").onclick=()=>{const open=tasks.filter(t=>!t.done);$(\"handoff\").textContent=open.length?open.map(t=>\"- [\"+t.priority+\"] \"+(t.room||\"No room\")+\": \"+t.need).join(\"\\n\"):\"No open items. Board is clear.\"};$(\"clear_done\").onclick=()=>{tasks=tasks.filter(t=>!t.done);save();render()};$(\"reset\").onclick=()=>{if(confirm(\"Reset the whole shift board?\")){tasks=[];save();render();$(\"handoff\").textContent=\"No handoff exported yet.\"}};render()})();</script></body></html>"
  }
}
